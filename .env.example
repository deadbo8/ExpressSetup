# ============================================
# ExpressVPN Gateway v2 — Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control!

# --- ExpressVPN ---
# Your ExpressVPN activation code (find it at https://www.expressvpn.com/setup)
ACTIVATION_CODE=YOUR_ACTIVATION_CODE_HERE

# ExpressVPN client version to install inside the container
EXPRESSVPN_VERSION=3.76.0.4-1

# Server location: 'smart' for auto, or a specific location like 'usny', 'uklo', 'sgju'
# Full list: https://www.expressvpn.com/vpn-server
EXPRESSVPN_SERVER=smart

# VPN protocol: lightway_udp (fastest), lightway_tcp, auto
PREFERRED_PROTOCOL=lightway_udp

# VPN mode: 'vpn' for full tunnel, 'direct' to bypass VPN temporarily
VPN_MODE=vpn

# --- Server ---
# Public IP address (or domain) of this server — used by WireGuard clients to connect
# Find yours with: curl ifconfig.me
SERVER_PUBLIC_IP=YOUR_SERVER_PUBLIC_IP_HERE

# --- WireGuard (wg-easy) ---
# Bcrypt hash of your WireGuard Web UI password
# Generate it with:
#   docker run -it ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
# IMPORTANT: Escape all $ signs in the hash by doubling them ($ → $$)
# Example: $$2a$$12$$abc... (note the double $$)
WG_PASSWORD_HASH=YOUR_PASSWORD_HASH_HERE

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Comma-separated list of Telegram user IDs allowed to use the bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=YOUR_TELEGRAM_USER_ID_HERE

# Chat ID for status notifications (usually same as your user ID for DMs)
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- AdGuard Home ---
# Initial AdGuard Home credentials (change these after first login at http://SERVER_IP:3000)
ADGUARD_USER=admin
ADGUARD_PASS=admin

# --- Dashboard ---
# PIN code for the web dashboard (change this to something secure!)
DASHBOARD_PIN=123456
